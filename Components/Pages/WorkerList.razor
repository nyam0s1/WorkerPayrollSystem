@page "/employees"
@rendermode InteractiveServer

@* Imports for database models and services *@
@using Blazor_Training.Domain
@inject Blazor_Training.Application.EmployeeService Service
@inject IJSRuntime JsRuntime

<nav class="navbar">
    <div class="logo">PayRoll System</div>
    <div class="nav-links">
        <NavLink href="" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink href="About">About</NavLink>
    </div>
</nav>

<div class="main-layout">
    <button class="sidebarToggle" @onclick="() => sidebarVisible = !sidebarVisible">☰</button>

    <nav class="@(sidebarVisible ? "sidebar" : "sidebar collapse")">
        <NavLink class="btn btn-blue" href="add">➕Add Employee</NavLink>
        <NavLink class="btn btn-blue" href="employees">📃View Employees</NavLink>
        <NavLink class="btn btn-blue" href="overtime">Overtime Section</NavLink>
        <NavLink class="btn btn-blue" href="calculator">🖩Tax Calculator</NavLink>
        <NavLink class="btn btn-blue" href="settings">⚙️Settings</NavLink>
    </nav>

    <div class="main-content">
        <h1>Employees Details</h1>

        @if (myEmployees.Count == 0)
        {
            <div class="card">
                <h3>No Workers in the system</h3>
                <p>Click <NavLink href="add">here</NavLink> to add workers to the system.</p>
            </div>
        }
        else
        {
            <div class="table">
                <div class="search-box">
                    <input type="text"
                           placeholder="🔍 Search by name"
                           @bind="searchText"
                           @bind:event="oninput"
                           @bind:after="PerformSearch">
                </div>

                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Hourly Pay</th>
                            <th>Hours Worked</th>
                            <th>Overtime Hours</th>
                            <th>Total Salary</th>
                            <th>Net Salary</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Employee w in myEmployees)
                        {
                            <tr @onclick="() => ToggleRow(w.Id)" class="clickable-row">

                                <td>@w.Name</td>
                                <td>@w.hourlyPay</td>
                                <td>@w.hoursWorked</td>

                                <td class="@(w.overTimeHours > 0 ? "text-danger fw-bold" : "")">
                                    @w.overTimeHours
                                </td>

                                <td>@w.totalSalary.ToString("N2")</td>

                                <td class="text-success fw-bold">
                                    @(w.CurrentPayslip != null ? w.CurrentPayslip.NetPay.ToString("N2") : "0.00")
                                </td>

                                <td>
                                    <a href="edit/@w.Id" class="btn btn-pink" @onclick:stopPropagation>🖋️</a>
                                    <button class="btn btn-pink" @onclick="() => DeleteEmployee(w)" @onclick:stopPropagation>🗑️</button>

                                    <button class="btn btn-blue" @onclick="() => ToggleRow(w.Id)" @onclick:stopPropagation>
                                        @(expandedRows.Contains(w.Id) ? "🔽" : "▶️")
                                    </button>
                                </td>
                            </tr>

                            @if (expandedRows.Contains(w.Id) && w.CurrentPayslip != null)
                            {
                                <tr class="drawer-row">
                                    <td colspan="7" class="drawer-cell">

                                        <div class="drawer-content">
                                            <h4 class="drawer-title">Payslip Breakdown</h4>

                                            <div class="drawer-table-wrapper">
                                                <table class="drawer-table">
                                                    <tbody>
                                                        <tr>
                                                            <td class="drawer-td"><strong>Gross Pay</strong></td>
                                                            <td class="drawer-td text-right"><strong>@w.CurrentPayslip.GrossPay.ToString("N2") KES</strong></td>
                                                        </tr>
                                                        <tr>
                                                            <td class="drawer-td text-danger">NSSF (Tier 1 & 2)</td>
                                                            <td class="drawer-td text-right text-danger">-@w.CurrentPayslip.NssfAmount.ToString("N2") KES</td>
                                                        </tr>
                                                        <tr>
                                                            <td class="drawer-td text-danger">PAYE (Tax)</td>
                                                            <td class="drawer-td text-right text-danger">-@w.CurrentPayslip.PayeAmount.ToString("N2") KES</td>
                                                        </tr>
                                                        <tr>
                                                            <td class="drawer-td text-danger">SHA (2.75%)</td>
                                                            <td class="drawer-td text-right text-danger">-@w.CurrentPayslip.ShaAmount.ToString("N2") KES</td>
                                                        </tr>
                                                        <tr>
                                                            <td class="drawer-td text-danger">Housing Levy (1.5%)</td>
                                                            <td class="drawer-td text-right text-danger">-@w.CurrentPayslip.HousingLevyAmount.ToString("N2") KES</td>
                                                        </tr>

                                                        <tr class="net-pay-row">
                                                            <td class="net-pay-text">Final Net Pay</td>
                                                            <td class="net-pay-text text-right">@w.CurrentPayslip.NetPay.ToString("N2") KES</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                            <div class="drawer-actions">
                                                <a href="payslip/@w.Id" class="btn btn-blue" @onclick:stopPropagation>🖨️ Official Payslip</a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code
{
    bool sidebarVisible = true;
    string searchText = "";
    List<Employee> myEmployees = new List<Employee>();

    // Keeps track of which specific table rows are currently expanded
    HashSet<Guid> expandedRows = new HashSet<Guid>();

    protected override async Task OnInitializedAsync()
    {
        // Grabs the employees AND calculates their exact taxes on page load
        myEmployees = await Service.GetAllEmployeesWithCalculatedPayAsync();
    }

    // Opens or closes the detailed tax breakdown drawer
    void ToggleRow(Guid employeeId)
    {
        if (expandedRows.Contains(employeeId))
            expandedRows.Remove(employeeId); // Close it
        else
            expandedRows.Add(employeeId);    // Open it
    }

    // Updated to async so the search results pass through the tax engine
    async Task PerformSearch()
    {
        myEmployees = await Service.SearchEmployeesWithCalculatedPayAsync(searchText);
    }

    async Task DeleteEmployee(Employee employee)
    {
        bool confirmed = await JsRuntime.InvokeAsync<bool>("confirm",
            $"Are you sure you want to delete {employee.Name}?");

        if (!confirmed)
            return;

        Service.DeleteEmployee(employee);

        // Updated to the async calculation method so the table refreshes correctly
        myEmployees = await Service.GetAllEmployeesWithCalculatedPayAsync();
    }
}