@page "/calculator"

@* Imports for our domain models and payroll logic interfaces *@
@using Blazor_Training.Domain
@using Blazor_Training.Application

@* Inject the standalone tax calculation engine *@
@inject IPayrollCalculatorService PayrollService

<nav class="navbar">
    <div class="logo">PayRoll System</div>
    <div class="nav-links">
        <NavLink href="" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink href="About">About</NavLink>
    </div>
</nav>

<div class="main-layout">
    <button class="sidebarToggle" @onclick="() => sidebarVisible = !sidebarVisible">☰</button>

    <nav class="@(sidebarVisible ? "sidebar" : "sidebar collapse")">
        <NavLink class="btn btn-blue" href="add">➕Add Employee</NavLink>
        <NavLink class="btn btn-blue" href="employees">📃View Employees</NavLink>
        <NavLink class="btn btn-blue" href="overtime">Overtime Section</NavLink>
        <NavLink class="btn btn-blue" href="calculator">🖩Tax Calculator</NavLink>
        <NavLink class="btn btn-blue" href="settings">⚙️Settings</NavLink>
    </nav>

    <div class="main-content">
        <h1>Kenyan Tax Calculator</h1>

        <p class="page-subtitle">Enter a monthly basic salary below to instantly calculate all statutory deductions.</p>

        <div class="table">

            <div class="calc-input-group">

                <input type="number"
                       class="form-control calc-input"
                       placeholder="Enter Basic Salary (KES)..."
                       @bind="inputSalary" />

                <button class="btn btn-blue calc-btn" @onclick="CalculateTax">Calculate</button>
            </div>

            @* Only show the breakdown table IF the user has clicked Calculate *@
            @if (generatedSlip != null)
            {
                <table>
                    <thead>
                        <tr>
                            <th class="text-left">Description</th>
                            <th class="text-right">Amount (KES)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Gross Pay</strong></td>
                            <td class="text-right font-weight-bold">@generatedSlip.GrossPay.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="text-danger">NSSF Deduction (Tier 1 & 2)</td>
                            <td class="text-right text-danger">- @generatedSlip.NssfAmount.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td>Taxable Pay</td>
                            <td class="text-right">@generatedSlip.TaxablePay.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="text-danger">PAYE (After KES 2,400 Relief)</td>
                            <td class="text-right text-danger">- @generatedSlip.PayeAmount.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="text-danger">SHA Deduction (2.75%)</td>
                            <td class="text-right text-danger">- @generatedSlip.ShaAmount.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td class="text-danger">Housing Levy (1.5%)</td>
                            <td class="text-right text-danger">- @generatedSlip.HousingLevyAmount.ToString("N2")</td>
                        </tr>

                        <tr class="net-pay-row">
                            <td class="net-pay-text">NET PAY</td>
                            <td class="text-right net-pay-text">@generatedSlip.NetPay.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    bool sidebarVisible = true;

    // Binds directly to the HTML input box above
    decimal? inputSalary;

    // Holds the final math results. Starts null so the table remains hidden initially.
    Payslip? generatedSlip;

    // Hardcoded KRA statutory limits for the standalone calculator
    private StatutoryConfig currentLaw = new StatutoryConfig
    {
        PersonalRelief = 2400m,
        NssfUpperLimit = 18000m,
        ShaRate = 0.0275m,
        HousingLevy = 0.015m
    };

    /// <summary>
    /// Triggers when the 'Calculate' button is clicked.
    /// Creates a dummy employee and passes it to the calculation engine.
    /// </summary>
    private void CalculateTax()
    {
        // 1. Create a temporary 'dummy' employee just for the math engine
        var dummyEmployee = new Employee
        {
            BasicSalary = inputSalary ?? 0,
            HouseAllowance = 0,
            TransportAllowance = 0,
            HasDisability = false
        };

        // 2. Fire the engine and store the result in 'generatedSlip' so the UI updates
        generatedSlip = PayrollService.GeneratePayslip(dummyEmployee, currentLaw);
    }
}