@page "/settings"
@rendermode InteractiveServer

@* Imports for our database models and application logic *@
@using Blazor_Training.Domain
@using Blazor_Training.Application

@* Inject the service that handles reading and writing the tax configurations *@
@inject SettingsService SettingsService

<nav class="navbar">
    <div class="logo">PayRoll System</div>
    <div class="nav-links">
        <NavLink href="" MatchMatch="NavLinkMatch.All">Home</NavLink>
        <NavLink href="About">About</NavLink>
    </div>
</nav>

<div class="main-layout">
    <button class="sidebarToggle" @onclick="() => sidebarVisible = !sidebarVisible">☰</button>
    <nav class="@(sidebarVisible ? "sidebar" : "sidebar collapse")">
        <NavLink class="btn btn-blue" href="add">➕Add Employee</NavLink>
        <NavLink class="btn btn-blue" href="employees">📃View Employees</NavLink>
        <NavLink class="btn btn-blue" href="overtime">Overtime Section</NavLink>
        <NavLink class="btn btn-blue" href="calculator">🖩Tax Calculator</NavLink>
        <NavLink class="btn btn-blue" href="settings">⚙️Settings</NavLink>
    </nav>

    <div class="main-content">
        <h1>Statutory Tax Settings</h1>

        <p class="page-subtitle">Manage the active KRA, NSSF, and SHA rates used by the calculation engine.</p>

        <div class="table settings-table">

            @* Show a loading message while we fetch the rules from the database *@
            @if (config == null)
            {
                <p><em>Loading current tax laws...</em></p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th class="text-left">Statutory Deduction</th>
                            <th class="text-center">Current Rate / Limit</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Personal Relief (KES)</strong></td>
                            <td class="text-center">
                                @* If in edit mode, show an input box bound to the config value *@
                                @if (isEditing)
                                {
                                    <input type="number" @bind="config.PersonalRelief" class="search-box input-small text-center" />
                                }
                                else
                                {
                                    <span>@config.PersonalRelief.ToString("N2")</span>
                                }
                            </td>

                            <td rowspan="4" class="actions-cell">
                                @if (isEditing)
                                {
                                    <button class="btn btn-success btn-block mb-10" @onclick="SaveChanges">💾 Save</button>
                                    <button class="btn btn-pink btn-block" @onclick="CancelEdit">❌ Cancel</button>
                                }
                                else
                                {
                                    <button class="btn btn-blue" @onclick="StartEditing">✏️ Edit Rates</button>
                                }
                            </td>
                        </tr>

                        <tr>
                            <td><strong>NSSF Upper Limit (KES)</strong></td>
                            <td class="text-center">
                                @if (isEditing)
                                {
                                    <input type="number" @bind="config.NssfUpperLimit" class="search-box input-small text-center" />
                                }
                                else
                                {
                                    <span>@config.NssfUpperLimit.ToString("N2")</span>
                                }
                            </td>
                        </tr>

                        <tr>
                            <td><strong>SHA Rate (Decimal)</strong></td>
                            <td class="text-center">
                                @if (isEditing)
                                {
                                    <input type="number" step="0.0001" @bind="config.ShaRate" class="search-box input-small text-center" />
                                }
                                else
                                {
                                    <span>@config.ShaRate</span>
                                }
                            </td>
                        </tr>

                        <tr>
                            <td><strong>Housing Levy (Decimal)</strong></td>
                            <td class="text-center">
                                @if (isEditing)
                                {
                                    <input type="number" step="0.001" @bind="config.HousingLevy" class="search-box input-small text-center" />
                                }
                                else
                                {
                                    <span>@config.HousingLevy</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    bool sidebarVisible = true;

    // Toggles between viewing the table and showing the input boxes
    bool isEditing = false;

    // Holds the active tax rules fetched from the database
    StatutoryConfig? config;

    /// <summary>
    /// Runs automatically when the page loads to fetch the current tax rules
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        config = await SettingsService.GetCurrentConfigAsync();
    }

    /// <summary>
    /// Switches the UI into Edit Mode
    /// </summary>
    private void StartEditing()
    {
        isEditing = true;
    }

    /// <summary>
    /// Discards any unsaved typing by re-fetching the original values from the DB
    /// </summary>
    private async Task CancelEdit()
    {
        config = await SettingsService.GetCurrentConfigAsync();
        isEditing = false;
    }

    /// <summary>
    /// Saves the new tax rates to the database and exits Edit Mode
    /// </summary>
    private async Task SaveChanges()
    {
        await SettingsService.SaveConfigAsync(config);
        isEditing = false;
    }
}