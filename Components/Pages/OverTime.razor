@page "/overtime"
@using Blazor_Training.Domain
@inject EmployeeService Service
@inject IJSRuntime JsRuntime

<nav class="navbar">
	<div class="logo">PayRoll System</div>
	<div class="nav-links">
		<NavLink href="" Match="NavLinkMatch.All">Home</NavLink>
		<NavLink href="About">About</NavLink>
	</div>
</nav>
<div class="main-layout">
	<button class="sidebarToggle" @onclick="() => sidebarVisible = !sidebarVisible">☰</button>
	<nav class="@(sidebarVisible ? "sidebar" : "sidebar collapse")">
		<NavLink class="btn btn-blue" href="add">➕Add Employee</NavLink>
		<NavLink class="btn btn-blue" href="employees">📃View Employees</NavLink>
		<NavLink class="btn btn-blue" href="overtime">Overtime Section</NavLink>
		<NavLink class="btn btn-blue" href="calculator">🖩Tax Calculator</NavLink>
		<NavLink class="btn btn-blue" href="settings">⚙️Settings</NavLink>
	</nav>

	<div class="main-content">
		<h1>Overtime Workers Details</h1>
		@if (overtimeEmployees.Count == 0)
		{
			<div class="card">
				<h3>No Overtime Detected</h3>
			</div>
		}
		else
		{
			<div class="table">
				<div class="search-box">
					<input type="text"
						   placeholder="🔍 Search by name"
						   @bind="searchText"
						   @bind:event="oninput"
						   @bind:after="PerformSearch">
				</div>
				<table>
					<thead>
						<tr>
							<th>Name</th>
							<th>Hourly Rate</th>
							<th>Overtime Hours</th>
							<th>Bonus Overtime Pay</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var w in overtimeEmployees)
						{
							<tr>
								<td>@w.Name</td>
								<td>@w.hourlyPay</td>
								<td>@w.overTimeHours hrs</td>
								<td>@( (w.overTimeHours * w.hourlyPay.GetValueOrDefault() * 1.5).ToString("N0") )</td>
								<td>
									<a href="edit/@w.Id" class="btn btn-pink">🖋️</a>
									<button class="btn btn-pink" @onclick="() => DeleteEmployee(w)">🗑️</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		}
	</div>
</div>

@code {
	bool sidebarVisible = true;
	string searchText = "";

	// We create a specific list just for this page
	List<Employee> overtimeEmployees = new List<Employee>();

	protected override void OnInitialized()
	{
		// 1. Get everyone
		var allEmployees = Service.GetAllEmployees();

		// 2. Filter: Keep ONLY people with Overtime > 0
		overtimeEmployees = allEmployees.Where(w => w.overTimeHours > 0).ToList();
	}

	void PerformSearch()
	{
		overtimeEmployees = Service.SearchEmployees(searchText);
	}

	async Task DeleteEmployee(Employee employee)
	{
		bool confirmed = await JsRuntime.InvokeAsync<bool>("confirm",
			$"Are you sure you want to delete {employee.Name}?");

		if (!confirmed)
			return;

		Service.DeleteEmployee(employee);

		PerformSearch();
	}
}