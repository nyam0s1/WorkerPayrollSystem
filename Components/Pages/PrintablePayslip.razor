@page "/payslip/{Id:guid}"
@rendermode InteractiveServer

@* Imports for database models *@
@using Blazor_Training.Domain
@inject Blazor_Training.Application.EmployeeService Service

@* If the data hasn't loaded yet, show a fallback message *@
@if (employee == null || employee.CurrentPayslip == null)
{
    <div class="main-content">
        <h3>Loading official document...</h3>
    </div>
}
else
{
    <div class="payslip-container">

        <div class="payslip-header">
            <h1 class="payslip-title">COMPANY PAYROLL SYSTEM</h1>
            <h3 class="payslip-subtitle">Official Employee Payslip</h3>
        </div>

        <div class="payslip-details">
            <div>
                <strong>Employee Name:</strong> @employee.Name<br />
                <strong>Employee ID:</strong> @employee.Id.ToString().Substring(0, 8).ToUpper()
            </div>
            <div class="text-right">
                <strong>Pay Period:</strong> @DateTime.Now.ToString("MMMM yyyy")<br />
                <strong>Date Printed:</strong> @DateTime.Now.ToString("dd MMM yyyy")
            </div>
        </div>

        <table class="payslip-table">
            <thead>
                <tr>
                    <th>Description</th>
                    <th class="text-right">Earnings (KES)</th>
                    <th class="text-right">Deductions (KES)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Basic Salary & Overtime (Gross Pay)</strong></td>
                    <td class="text-right"><strong>@employee.CurrentPayslip.GrossPay.ToString("N2")</strong></td>
                    <td></td>
                </tr>
                <tr>
                    <td>NSSF Deduction (Tier 1 & 2)</td>
                    <td></td>
                    <td class="text-right text-danger">-@employee.CurrentPayslip.NssfAmount.ToString("N2")</td>
                </tr>
                <tr>
                    <td>PAYE (Income Tax)</td>
                    <td></td>
                    <td class="text-right text-danger">-@employee.CurrentPayslip.PayeAmount.ToString("N2")</td>
                </tr>
                <tr>
                    <td>SHA Deduction (2.75%)</td>
                    <td></td>
                    <td class="text-right text-danger">-@employee.CurrentPayslip.ShaAmount.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Housing Levy (1.5%)</td>
                    <td></td>
                    <td class="text-right text-danger">-@employee.CurrentPayslip.HousingLevyAmount.ToString("N2")</td>
                </tr>
            </tbody>
            <tfoot>
                <tr class="payslip-net-row">
                    <th colspan="2" class="text-right payslip-net-label">FINAL NET PAY:</th>
                    <th class="text-right payslip-net-value">@employee.CurrentPayslip.NetPay.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>

        <div class="payslip-actions">
            <button class="btn btn-blue print-btn" onclick="window.print()">🖨️ Print to PDF</button>
            <a href="employees" class="btn btn-pink print-btn">⬅️ Back to List</a>
        </div>
    </div>
}

@code {
    // Catches the exact ID from the URL address bar
    [Parameter]
    public Guid Id { get; set; }

    private Employee? employee;

    protected override async Task OnInitializedAsync()
    {
        // 1. Fetch everyone with their taxes calculated
        var allEmployees = await Service.GetAllEmployeesWithCalculatedPayAsync();

        // 2. Find the exact employee who matches the ID in the URL
        employee = allEmployees.FirstOrDefault(e => e.Id == Id);
    }
}